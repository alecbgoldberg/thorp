# Template for secrets/odds.env (which is gitignored). Copy to secrets/odds.env
# and fill in. The odds provider is swappable — each provider reads its own key
# env var, so switching later is a config change plus a new key here.

# OddsPapi (current provider — free tier, no credit card): https://oddspapi.io
THORP_ODDSPAPI_API_KEY=""

# Future providers — uncomment/add when you switch:
# THORP_THEODDSAPI_API_KEY=""
# THORP_SHARPAPI_API_KEY=""
# THORP_SPORTSGAMEODDS_API_KEY=""

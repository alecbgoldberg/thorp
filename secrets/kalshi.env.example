# Template for secrets/kalshi.env (which is gitignored). Copy this file to
# secrets/kalshi.env and fill it in — see secrets/README.md for the full guide.
#
# Two Kalshi keys, never interchangeable:
#   READ-ONLY -> Recorder + SIMULATION/BACKTEST (Kalshi `read` scope only)
#   FULL      -> live trading only (`read` + `write::trade`, never withdraw)

THORP_KALSHI_READONLY_KEY_ID=""
THORP_KALSHI_READONLY_PRIVATE_KEY="secrets/kalshi-readonly.pem"

THORP_KALSHI_FULL_KEY_ID=""
THORP_KALSHI_FULL_PRIVATE_KEY="secrets/kalshi-full.pem"

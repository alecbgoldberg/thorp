# Secrets — never commit these
.env
.env.*
*.pem
*.key
kalshi_api_key*
# Ignore everything in secrets/ except the committed templates + README.
secrets/*
!secrets/kalshi.env.example
!secrets/odds.env.example
!secrets/README.md

# Log output (trade log + separate fills log)
logs/
# Research study outputs (regenerable)
research/**/output/

# Local data — all generated (raw capture, demo + live engine sessions)
data/
*.db
*.sqlite3

# Python
__pycache__/
*.pyc
.venv/
venv/
.mypy_cache/
.pytest_cache/
.hypothesis/
.ruff_cache/
.coverage
htmlcov/

# Local (non-example) runtime config may embed account-specific values
config/recorder.toml
config/odds.toml
config/tracker.toml

# OS
.DS_Store

# Claude Code local session config
.claude/
config/collector.toml
